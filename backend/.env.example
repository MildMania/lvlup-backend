PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/lvlup?schema=public"
OPENAI_API_KEY="your-openai-api-key-here"
CORS_ORIGIN="http://localhost:5173"

# Runtime mode
RUN_API=true
RUN_JOBS=true

# Hourly aggregation toggles (daily jobs still run)
ENABLE_LEVEL_METRICS_HOURLY=0
LEVEL_CHURN_HOURLY_REFRESH=0
LEVEL_METRICS_DAILY_CHUNKED=1
ENABLE_ACTIVE_USERS_HOURLY=0
ENABLE_COHORT_HOURLY=0
ENABLE_MONETIZATION_HOURLY=0
ENABLE_CLICKHOUSE_PIPELINE=0
ACTIVE_USERS_DAILY_CHUNKED=1
COHORT_DAYINDEX_CHUNK_SIZE=8
MONETIZATION_DAILY_CHUNKED=1
AGGREGATION_PAUSE_MS=0
AGGREGATION_FORCE_GC=0

# Session heartbeat write controls
HEARTBEAT_MIN_PERSIST_INTERVAL_SECONDS=60
HEARTBEAT_PERSIST_DURATION=0
HEARTBEAT_BATCH_UPDATE_CHUNK_SIZE=250

# API key auth cache (reduces repeated game lookups)
AUTH_GAME_CACHE_TTL_SECONDS=60
AUTH_GAME_NEG_CACHE_TTL_SECONDS=10
AUTH_GAME_CACHE_MAX_ENTRIES=10000

# Optional diagnostics
ANALYTICS_TRACE=0
ANALYTICS_TRACE_SLOW_MS=1000
# Set to 1 only if you want slow query traces as warn logs
ANALYTICS_TRACE_WARN=0
# Feature flag: read /analytics/events from ClickHouse with Postgres fallback
ANALYTICS_READ_EVENTS_FROM_CLICKHOUSE=0
# Feature flag: read /analytics/metrics/revenue-summary from ClickHouse with Postgres fallback
ANALYTICS_READ_REVENUE_SUMMARY_FROM_CLICKHOUSE=0
# Feature flag: read /analytics/metrics/active-users from ClickHouse with Postgres fallback
ANALYTICS_READ_ACTIVE_USERS_FROM_CLICKHOUSE=0
# Feature flag: read /analytics/metrics/retention from ClickHouse with Postgres fallback
ANALYTICS_READ_RETENTION_FROM_CLICKHOUSE=0
# Feature flag: read /analytics/metrics/playtime from ClickHouse with Postgres fallback
ANALYTICS_READ_PLAYTIME_FROM_CLICKHOUSE=0
# Feature flag: read /analytics/cohort/* metrics from ClickHouse with Postgres fallback
ANALYTICS_READ_COHORT_FROM_CLICKHOUSE=0
# Feature flag: read /level-funnel from ClickHouse with Postgres fallback
ANALYTICS_READ_LEVEL_FUNNEL_FROM_CLICKHOUSE=0

# ClickHouse pilot sync
CLICKHOUSE_URL=""
CLICKHOUSE_DATABASE="default"
CLICKHOUSE_USER=""
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_SYNC_TABLES="events,revenue,sessions,users,cohort_retention_daily,cohort_session_metrics_daily,level_metrics_daily,level_metrics_daily_users,level_churn_cohort_daily"
CLICKHOUSE_SYNC_BATCH_SIZE=10000
CLICKHOUSE_SYNC_MAX_BATCHES=5
CLICKHOUSE_SYNC_CRON="*/5 * * * *"
CLICKHOUSE_HTTP_TIMEOUT_MS=15000
CLICKHOUSE_PING_TIMEOUT_MS=30000
